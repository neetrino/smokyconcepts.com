{
  "name": "@white-shop/db",
  "version": "1.0.0",
  "private": true,
  "main": "index.ts",
  "types": "index.ts",
  "scripts": {
    "db:generate": "node scripts/generate-with-env.js",
    "db:push": "npx prisma db push",
    "db:migrate": "npx prisma migrate dev",
